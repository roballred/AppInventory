# ─────────────────────────────────────────────────────────────────────────────
# State Application Inventory — Environment Variables
#
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to source control.
# ─────────────────────────────────────────────────────────────────────────────

# Database
DATABASE_URL=postgresql://appinventory:appinventory@localhost:5432/appinventory

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-random-secret-string

# Identity Provider — generic variable names, works with any OIDC/SAML provider
# Microsoft Entra ID: find these in Azure Portal > App Registrations
# Okta: find in Applications > your app > General Settings
# PingFederate / Auth0: use equivalent values from your provider's app registration
IDENTITY_PROVIDER_CLIENT_ID=your-client-id
IDENTITY_PROVIDER_CLIENT_SECRET=your-client-secret
IDENTITY_PROVIDER_ISSUER_URL=your-issuer-url
# Note: IDENTITY_PROVIDER_TENANT_ID is Entra ID-specific.
# For Entra ID: https://login.microsoftonline.com/{tenant-id}
# For other providers: use IDENTITY_PROVIDER_ISSUER_URL above instead
