# ─────────────────────────────────────────────────────────────────────────────
# State Application Inventory — Environment Variables
#
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to source control.
# ─────────────────────────────────────────────────────────────────────────────

# Database
DATABASE_URL=postgresql://appinventory:appinventory@localhost:5432/appinventory

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-random-secret-string

# Identity Provider (Microsoft Entra ID example — replace with your provider)
# For Entra ID: find these in Azure Portal > App Registrations
# For other providers (Okta, PingFederate, Auth0): replace with equivalent values
IDENTITY_PROVIDER_CLIENT_ID=your-client-id
IDENTITY_PROVIDER_CLIENT_SECRET=your-client-secret
IDENTITY_PROVIDER_TENANT_ID=your-tenant-id
