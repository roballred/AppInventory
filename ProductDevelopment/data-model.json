{
  "version": "v1",
  "created": "2026-03-27",
  "product": "State Application Inventory",
  "database": "PostgreSQL",
  "description": "Core data model for the State Application Inventory web app. Fields are derived from the state IT portfolio policy standard (Washington State MGMT-01-01-S used as example — adopting states should map to their own equivalent policy). Audit log captures full field-level change history.",

  "entities": {

    "Agency": {
      "description": "A state agency that owns application inventory records.",
      "fields": {
        "id": { "type": "UUID", "primaryKey": true },
        "name": { "type": "string", "required": true },
        "agency_number": { "type": "string", "required": true, "note": "Official agency number from the state IT authority's portfolio standard" },
        "identity_group_id": { "type": "string", "required": true, "note": "Identity provider group ID linking agency to its users" },
        "created_at": { "type": "timestamp", "required": true },
        "updated_at": { "type": "timestamp", "required": true }
      }
    },

    "User": {
      "description": "A person who accesses the system, authenticated via the state identity provider.",
      "fields": {
        "id": { "type": "UUID", "primaryKey": true },
        "identity_id": { "type": "string", "required": true, "note": "Identity provider object ID — used for SSO mapping" },
        "agency_id": { "type": "UUID", "foreignKey": "Agency.id", "required": true },
        "role": {
          "type": "enum",
          "required": true,
          "allowedValues": ["platform_admin", "agency_admin", "submitter", "viewer"],
          "note": "platform_admin can see all agencies; all others are scoped to their agency only"
        },
        "display_name": { "type": "string", "required": true },
        "email": { "type": "string", "required": true },
        "created_at": { "type": "timestamp", "required": true },
        "updated_at": { "type": "timestamp", "required": true }
      }
    },

    "Application": {
      "description": "A single application record in an agency's inventory. Minimum v1 field set — fields that change regularly and are most likely to have wrong values.",
      "fields": {
        "id": { "type": "UUID", "primaryKey": true },
        "agency_id": { "type": "UUID", "foreignKey": "Agency.id", "required": true },
        "name": { "type": "string", "required": true },
        "description": { "type": "string", "required": false },
        "version": { "type": "string", "required": false },
        "lifecycle_status": {
          "type": "enum",
          "required": true,
          "allowedValues": [
            "In development",
            "In production",
            "Retirement in progress",
            "Retired from inventory"
          ]
        },
        "manufacturer_vendor": { "type": "string", "required": false },
        "cloud_service_provider": { "type": "string", "required": false },
        "operating_system": { "type": "string", "required": false },
        "os_version": { "type": "string", "required": false },
        "contract_number": { "type": "string", "required": false },
        "license_number": { "type": "string", "required": false },
        "in_service_production_date": { "type": "date", "required": false },
        "retirement_date": { "type": "date", "required": false },
        "is_unsupported_version": { "type": "boolean", "required": false },
        "is_updatable": { "type": "boolean", "required": false },
        "is_aging_technology": { "type": "boolean", "required": false },
        "is_ai_enabled": { "type": "boolean", "required": false },
        "is_generative_ai": { "type": "boolean", "required": false },
        "last_reviewed_at": { "type": "timestamp", "required": true, "note": "Drives staleness detection in business rules" },
        "created_at": { "type": "timestamp", "required": true },
        "updated_at": { "type": "timestamp", "required": true },
        "created_by": { "type": "UUID", "foreignKey": "User.id", "required": true },
        "updated_by": { "type": "UUID", "foreignKey": "User.id", "required": true }
      }
    },

    "ApplicationAuditLog": {
      "description": "Full field-level change history for every application record. Powers staleness detection, refresh rate metrics, and compliance audit trails.",
      "fields": {
        "id": { "type": "UUID", "primaryKey": true },
        "application_id": { "type": "UUID", "foreignKey": "Application.id", "required": true },
        "user_id": { "type": "UUID", "foreignKey": "User.id", "required": true },
        "action": {
          "type": "enum",
          "required": true,
          "allowedValues": ["created", "updated", "retired"]
        },
        "field_changes": {
          "type": "JSONB",
          "required": false,
          "note": "Array of { field, old_value, new_value } for each changed field. Null on create."
        },
        "created_at": { "type": "timestamp", "required": true }
      }
    },

    "Notification": {
      "description": "Alerts generated by business rules and sent to users.",
      "fields": {
        "id": { "type": "UUID", "primaryKey": true },
        "rule_id": { "type": "string", "required": true, "note": "References a rule ID in business-rules.json" },
        "agency_id": { "type": "UUID", "foreignKey": "Agency.id", "required": true },
        "user_id": { "type": "UUID", "foreignKey": "User.id", "required": true },
        "application_id": { "type": "UUID", "foreignKey": "Application.id", "required": false, "note": "Nullable — some notifications are agency-level, not application-level" },
        "channel": {
          "type": "enum",
          "required": true,
          "allowedValues": ["email", "in-app"]
        },
        "message": { "type": "string", "required": true },
        "sent_at": { "type": "timestamp", "required": true },
        "read_at": { "type": "timestamp", "required": false, "note": "Null until user reads the notification" }
      }
    },

    "Certification": {
      "description": "Annual certification submission record per agency.",
      "fields": {
        "id": { "type": "UUID", "primaryKey": true },
        "agency_id": { "type": "UUID", "foreignKey": "Agency.id", "required": true },
        "certification_year": { "type": "integer", "required": true },
        "status": {
          "type": "enum",
          "required": true,
          "allowedValues": ["not_started", "in_progress", "submitted", "approved"]
        },
        "submitted_at": { "type": "timestamp", "required": false },
        "submitted_by": { "type": "UUID", "foreignKey": "User.id", "required": false },
        "approved_at": { "type": "timestamp", "required": false },
        "approved_by": { "type": "UUID", "foreignKey": "User.id", "required": false, "note": "Platform admin who approves the submission" },
        "created_at": { "type": "timestamp", "required": true },
        "updated_at": { "type": "timestamp", "required": true }
      }
    }

  },

  "relationships": [
    { "from": "User", "to": "Agency", "type": "many-to-one", "note": "Many users belong to one agency" },
    { "from": "Application", "to": "Agency", "type": "many-to-one", "note": "Many applications belong to one agency" },
    { "from": "ApplicationAuditLog", "to": "Application", "type": "many-to-one", "note": "Many audit log entries per application" },
    { "from": "ApplicationAuditLog", "to": "User", "type": "many-to-one", "note": "Each log entry is attributed to a user" },
    { "from": "Notification", "to": "Agency", "type": "many-to-one" },
    { "from": "Notification", "to": "User", "type": "many-to-one" },
    { "from": "Notification", "to": "Application", "type": "many-to-one", "note": "Optional — application-level notifications only" },
    { "from": "Certification", "to": "Agency", "type": "many-to-one", "note": "One certification record per agency per year" }
  ]
}
